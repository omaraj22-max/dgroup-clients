# ─────────────────────────────────────────────────────────────
#  Copia este archivo a  .env.local  y pega tu URL /exec de Apps Script.
#  (En Vercel se configura como Environment Variable, ver README.)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/PEGA_TU_ID_AQUI/exec

# (OPCIONAL) Solo si quieres traer fotos de lugares de Google Maps.
# Requiere una API key de Google Cloud con "Places API (New)" + billing.
# OJO: NO lleva el prefijo NEXT_PUBLIC_ — es secreta y solo se usa en el servidor.
GOOGLE_MAPS_API_KEY=
